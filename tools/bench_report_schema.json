            "gap": {
              "type": "integer",
              "minimum": 0
            },
            "gapDirected": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "correctness": {
      "type": "object",
      "required": [
        "goldenSim",
        "cppReference",
        "digestMatch"
      ],
      "properties": {
        "goldenSim": {
          "type": "object",
          "required": [
            "ok",
            "digests",
            "digestPath",
            "tracePath",
            "error"
          ],
          "properties": {
            "ok": {
              "type": "boolean"
            },
            "digests": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "digestPath": {
              "type": "string"
            },
            "tracePath": {
              "type": "string"
            },
            "error": {
              "type": [
                "string",
                "null"
              ]
            }
          }
        },
        "cppReference": {
          "type": "object",
          "required": [
            "ok",
            "digests",
            "binaryPath",
            "error"
          ],
          "properties": {
            "ok": {
              "type": "boolean"
