{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "NEMA Bench Report Schema v0.1",
  "type": "object",
  "required": [
    "ok",
    "modelId",
    "bench",
    "gitCommit",
    "createdAt",
    "toolchainVersions",
    "config",
    "provenance",
    "graphResolved",
    "correctness",
    "performance",
    "hardware",
    "ticks",
    "irPath",
    "irSha256",
    "artifacts",
    "validation"
  ],
  "properties": {
    "ok": {
      "type": "boolean"
    },
    "modelId": {
      "type": "string",
      "minLength": 1
    },
    "bench": {
      "type": "object",
      "required": [
        "targetId"
      ],
      "properties": {
        "targetId": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "gitCommit": {
      "type": [
        "string",
        "null"
      ]
    },
    "createdAt": {
      "type": "string",
      "minLength": 1
    },
    "toolchainVersions": {
      "type": "object",
      "required": [
        "python",
        "g++",
        "vitis_hls",
        "vivado"
      ],
      "properties": {
        "python": {
          "type": [
            "string",
            "null"
          ]
        },
        "g++": {
          "type": [
            "string",
            "null"
          ]
        },
        "vitis_hls": {
          "type": [
            "string",
            "null"
          ]
        },
        "vivado": {
          "type": [
            "string",
            "null"
          ]
        }
      }
    },
    "config": {
      "type": "object",
      "required": [
        "qformats",
        "dt",
        "dtNanoseconds",
        "schedule",
        "graph"
      ],
      "properties": {
        "qformats": {
          "type": "object"
        },
        "dt": {
          "type": [
            "number",
            "string"
          ]
        },
        "dtNanoseconds": {
          "type": [
            "integer",
            "null"
          ]
        },
        "schedule": {
          "type": "object",
          "required": [
            "policy",
            "snapshotRule",
            "evalOrder",
            "synapseLanes",
            "neuronLanes"
          ],
          "properties": {
            "policy": {
              "type": "string"
            },
            "snapshotRule": {
              "type": "boolean"
            },
            "evalOrder": {
              "type": "string"
            },
            "synapseLanes": {
              "type": "integer",
              "minimum": 1
            },
            "neuronLanes": {
              "type": "integer",
              "minimum": 1
            }
          }
        },
        "graph": {
          "type": "object",
          "required": [
            "nodeCount",
            "chemicalEdgeCount",
            "gapEdgeCount",
            "edgeCountTotal"
          ],
          "properties": {
            "nodeCount": {
              "type": "integer",
              "minimum": 0
            },
            "chemicalEdgeCount": {
              "type": "integer",
              "minimum": 0
            },
            "gapEdgeCount": {
              "type": "integer",
              "minimum": 0
            },
            "edgeCountTotal": {
              "type": "integer",
              "minimum": 0
            }
          }
        }
      }
    },
    "provenance": {
      "type": "object",
      "required": [
        "syntheticUsed",
        "externalVerified"
      ],
      "properties": {
        "syntheticUsed": {
          "type": "boolean"
        },
        "externalVerified": {
          "type": "boolean"
        }
      }
    },
    "graphResolved": {
      "type": "object",
      "required": [
        "nodeCount",
        "edgeCounts"
      ],
      "properties": {
        "nodeCount": {
          "type": "integer",
          "minimum": 0
